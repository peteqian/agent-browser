{
  "name": "@browser-agent/core",
  "version": "0.0.1",
  "description": "TypeScript browser automation agent. Raw CDP + LLM loop, inspired by browser-use.",
  "keywords": [
    "agent",
    "automation",
    "browser",
    "cdp",
    "chrome-devtools",
    "llm",
    "mcp"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./internal": {
      "types": "./dist/src/internal.d.ts",
      "import": "./dist/src/internal.js"
    }
  },
  "bin": {
    "browser-agent": "./dist/bin/cli.js",
    "browser-agent-mcp": "./dist/bin/mcp.js"
  },
  "files": ["dist", "README.md", "AGENTS.md", "CHANGELOG.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/internal.ts bin/cli.ts bin/mcp.ts --format esm --dts --out-dir dist --clean --sourcemap",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "cli": "node ./dist/bin/cli.js",
    "mcp": "node ./dist/bin/mcp.js",
    "dev:cli": "bun run ./bin/cli.ts",
    "dev:mcp": "bun run ./bin/mcp.ts",
    "example:goto": "bun run examples/goto.ts",
    "example:agent": "bun run examples/agent.ts",
    "example:typed-output": "bun run examples/typed-output.ts",
    "example:openai": "bun run examples/openai-agent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "devtools-protocol": "^0.0.1617013",
    "openai": "^6.35.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
